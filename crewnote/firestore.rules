rules_version = '2';

// ===========================================
// CrewNote Firestore 보안 규칙
// Firebase 콘솔 → Firestore Database → 규칙(Rules) 탭에 붙여넣고 "게시"
// ===========================================

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }
    // 해당 팀의 팀장인지 (teams/{teamId}.leaderId == 나)
    function isTeamLeader(teamId) {
      return teamId != null
        && exists(/databases/$(database)/documents/teams/$(teamId))
        && get(/databases/$(database)/documents/teams/$(teamId)).data.leaderId == request.auth.uid;
    }

    // 사용자 문서: 로그인 유저는 읽기 가능(팀원 표시용), 본인만 수정
    match /users/{uid} {
      allow read: if signedIn();
      allow create, update: if isSelf(uid);
    }

    // 팀 문서: 로그인 유저 읽기(참여 코드 조회 포함), 팀장으로 생성, 로그인 유저 업데이트(참여)
    match /teams/{teamId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.leaderId == request.auth.uid;
      allow update: if signedIn();
    }

    // 노트: 본인 또는 같은 팀 팀장만 읽기. 작성/수정/삭제는 본인만.
    match /notes/{noteId} {
      allow read: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        isTeamLeader(resource.data.teamId)
      );
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
