# ===========================================
# CrewNote нҷҳкІҪліҖмҲҳ м„Өм •
# ===========================================
# мқҙ нҢҢмқјмқ„ ліөмӮ¬н•ҳм—¬ .env.localмқ„ мғқм„ұн•ҳм„ёмҡ”:
#   cp .env.example .env.local
#
# вҡ пёҸ .env.localмқҖ м ҲлҢҖ Gitм—җ м»Өл°Ӣн•ҳм§Җ л§Ҳм„ёмҡ”!
# ===========================================

# ===========================================
# Firebase м„Өм • (нҒҙлқјмқҙм–ёнҠё - лёҢлқјмҡ°м Җ л…ём¶ң OK)
# ===========================================
# Firebase Console вҶ’ н”„лЎңм қнҠё м„Өм • вҶ’ мқјл°ҳ вҶ’ мӣ№м•ұм—җм„ң нҷ•мқё
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ===========================================
# Firebase Admin SDK (м„ңлІ„ м „мҡ© - м ҲлҢҖ л…ём¶ң кёҲм§Җ!)
# ===========================================
# Firebase Console вҶ’ н”„лЎңм қнҠё м„Өм • вҶ’ м„ңл№„мҠӨ кі„м • вҶ’ мғҲ л№„кіөк°ң нӮӨ мғқм„ұ
# лӢӨмҡҙлЎңл“ңн•ң JSON нҢҢмқјмқҳ кІҪлЎңлҘј м§Җм • (н”„лЎңм қнҠё лЈЁнҠё кё°мӨҖ мғҒлҢҖ кІҪлЎң)
# мҳҲ: ./firebase-adminsdk-xxxxx.json
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# ===========================================
# OpenRouter API (м„ңлІ„ м „мҡ© - м ҲлҢҖ л…ём¶ң кёҲм§Җ!)
# ===========================================
# https://openrouter.ai/keys м—җм„ң л°ңкёү
OPENROUTER_API_KEY=your_openrouter_api_key

# LLM лӘЁлҚё м„Өм • (OpenRouter лӘЁлҚёлӘ…)
# м¶”мІң: google/gemini-2.5-flash (н•ңкөӯм–ҙ кө¬мЎ°нҷ” мҡ°мҲҳ, л№ лҰ„, м Җл ҙ)
# лҢҖм•Ҳ: openai/gpt-4o-mini, anthropic/claude-haiku-4.5
OPENROUTER_MODEL=google/gemini-2.5-flash
